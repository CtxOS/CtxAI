# --- Line Endings ---
* text=auto eol=lf

# --- Language-Specific ---
*.py text diff=python
*.js text
*.ts text
*.html text
*.css text
*.md text
*.toml text
*.yaml text
*.yml text
*.json text
*.sh text eol=lf
Makefile text

# --- Binary Files ---
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary

# --- Linguist (GitHub) Support ---
# Exclude certain files from language statistics
docs/* linguist-documentation
data/* linguist-vendored
tests/* linguist-test