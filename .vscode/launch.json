{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug run_ui.py",
      "type": "debugpy",
      "request": "launch",
      "program": "./src/ctxai/run_ui.py",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "src"
      },
      "args": ["--development=true"]
    },
    {
      "name": "Debug current file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "src"
      }
    },
    {
      "name": "Python: Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${workspaceFolder}/tests/"],
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "src"
      }
    }
  ]
}
